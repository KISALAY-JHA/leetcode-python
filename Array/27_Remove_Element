# LeetCode #27 - Remove Element
# https://leetcode.com/problems/remove-element/
#
# Difficulty: Easy
# Time Complexity: O(n)
# Space Complexity: O(1)

class Solution:
    def removeElement(self, nums: List[int], val: int) -> int:
        k=0
# Traverse the array
        for i in range (len(nums)):
            if nums[i]!= val:
                nums[k] = nums[i]
                k+= 1
        return k
